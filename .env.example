# Database (Prisma / SQLite)
DATABASE_URL="file:./dev.db"

# Auth Secret (Auth.js v5) — generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of this app — used for status-page links in emails. Point your cron
# job at this host too (e.g. http://localhost:3000).
APP_URL=http://localhost:3000

# Optional email notifications. When any required SMTP value is missing, email
# delivery no-ops to the server console so status changes still succeed.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional off-box backups. scripts/backup-db.sh copies successful snapshots to
# this rclone destination when set, e.g. gdrive:church-comms-backups.
BACKUP_REMOTE=

# ──────────────────────────────────────────────────────────────────────────
# Planning Center API (read-only Calendar import)
# ──────────────────────────────────────────────────────────────────────────
# Model A pulls APPROVED Calendar events (with their booked rooms) down from
# Planning Center. We never write back to PCO.
#
# Preferred: use a Planning Center Personal Access Token pair. Create one in
# the PCO developer console
# (https://api.planningcenteronline.com/oauth/applications) under
# "Personal Access Tokens".
PLANNING_CENTER_APP_ID=
PLANNING_CENTER_SECRET=

# Alternative 1: this app's own HTTP Basic Personal Access Token pair.
# PCO_APP_ID=
# PCO_SECRET=

# Alternative 2: an OAuth bearer token.
# PCO_TOKEN=

# Shared secret guarding the scheduled sync endpoint (GET/POST
# /api/cron/sync-events). Generate with: openssl rand -base64 32
# The cron job must present it as `Authorization: Bearer <CRON_SECRET>` (or
# ?key=<CRON_SECRET>). If unset, the endpoint rejects every request (401).
CRON_SECRET=

# Optional Google/iCal import preview. GOOGLE_EVENTS_CALENDAR_URL can be a human
# calendar page; GOOGLE_EVENTS_ICAL_URL should be an ICS feed. ICAL_IMPORT_FILE
# points the admin-only local iCal importer at a file on disk.
GOOGLE_EVENTS_CALENDAR_URL=
GOOGLE_EVENTS_ICAL_URL=
ICAL_IMPORT_FILE=
